---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'carles.sh',
  description = 'Personal website of Carles.',
} = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/music', label: 'Music' },
];

const normalizePath = (path: string) => (path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path);
const currentPath = normalizePath(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#41bfe8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-window" aria-label="Site header">
        <div class="titlebar">
          <a class="brand" href="/" aria-label="carles.sh home">
            <span class="brand-mark" aria-hidden="true">C</span>
            <span>
              <strong>carles.sh</strong>
              <small>personal homepage</small>
            </span>
          </a>
          <div class="window-controls" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>

        <nav class="primary-nav" aria-label="Primary navigation">
          {navItems.map((item) => {
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <a href={item.href} aria-current={isActive ? 'page' : undefined}>
                {item.label}
              </a>
            );
          })}
        </nav>
      </header>

      <slot />

      <footer class="site-footer">
        <span>carles.sh</span>
        <span>Built as a small personal web home, not a content farm.</span>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --ink: #072d43;
    --ink-strong: #031927;
    --muted: #315d72;
    --paper: rgba(248, 254, 255, 0.82);
    --panel: rgba(255, 255, 255, 0.48);
    --panel-solid: rgba(255, 255, 255, 0.78);
    --line: rgba(255, 255, 255, 0.82);
    --line-blue: rgba(11, 121, 185, 0.26);
    --blue: #0b8bd3;
    --blue-deep: #07588e;
    --green: #44ba5f;
    --green-deep: #1f7b3b;
    --amber: #f49b24;
    --rose: #d84ba3;
    --cyan: #42d7ff;
    --shadow: rgba(0, 45, 88, 0.3);
    --shadow-deep: rgba(0, 31, 66, 0.42);
    --radius-xl: 24px;
    --radius-lg: 17px;
    --radius-md: 12px;
    --max-width: 1120px;
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  html {
    min-height: 100%;
    scroll-behavior: smooth;
    cursor: url('/cursors/retro-pointer.svg') 4 2, auto;
  }

  body {
    min-height: 100vh;
    margin: 0;
    color: var(--ink);
    font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
    letter-spacing: 0;
    background:
      radial-gradient(circle at 18% 10%, rgba(255, 255, 255, 0.9) 0 2.5%, transparent 16%),
      radial-gradient(circle at 78% 18%, rgba(126, 255, 207, 0.54) 0 6%, transparent 28%),
      radial-gradient(circle at 82% 82%, rgba(37, 158, 230, 0.36) 0 7%, transparent 30%),
      linear-gradient(135deg, rgba(61, 212, 255, 0.62), transparent 36%),
      linear-gradient(225deg, rgba(106, 228, 88, 0.42), transparent 42%),
      linear-gradient(180deg, #85dfff 0%, #cbf6ff 44%, #b9ef8d 100%);
    overflow-x: hidden;
  }

  body::before {
    position: fixed;
    inset: 0;
    z-index: -2;
    content: '';
    pointer-events: none;
    background:
      linear-gradient(115deg, transparent 0 12%, rgba(255, 255, 255, 0.48) 15%, transparent 24% 100%),
      linear-gradient(rgba(255, 255, 255, 0.18) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.14) 1px, transparent 1px);
    background-size: auto, 52px 52px, 52px 52px;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.52), transparent 76%);
  }

  body::after {
    position: fixed;
    inset: auto 0 0;
    z-index: -1;
    height: 42vh;
    content: '';
    pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 100%, rgba(255, 255, 255, 0.72), transparent 60%),
      linear-gradient(180deg, transparent, rgba(43, 172, 205, 0.18));
  }

  a,
  button {
    cursor: url('/cursors/retro-pointer.svg') 4 2, pointer;
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  p {
    color: var(--muted);
    line-height: 1.68;
  }

  ::selection {
    color: #fff;
    background: rgba(5, 104, 170, 0.86);
  }

  .site-shell {
    width: min(var(--max-width), calc(100% - 28px));
    margin: 22px auto 36px;
  }

  .site-window,
  .glass-panel,
  .media-panel,
  .content-card {
    border: 1px solid var(--line);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.66), rgba(255, 255, 255, 0.24)),
      var(--panel);
    background-color: rgba(255, 255, 255, 0.5);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 0 0 1px rgba(255, 255, 255, 0.26),
      0 20px 54px var(--shadow);
    backdrop-filter: blur(14px) saturate(145%);
    -webkit-backdrop-filter: blur(14px) saturate(145%);
  }

  .site-window {
    overflow: hidden;
    border-radius: var(--radius-xl);
  }

  .titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 13px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.56);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.32) 48%, rgba(26, 145, 209, 0.28)),
      rgba(255, 255, 255, 0.38);
  }

  .brand {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    align-items: center;
    min-width: 0;
    gap: 12px;
    color: inherit;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.86);
    border-radius: 14px;
    color: #fff;
    font-weight: 900;
    text-shadow: 0 1px 2px rgba(0, 61, 112, 0.7);
    background:
      radial-gradient(circle at 35% 22%, #fff 0 13%, rgba(255, 255, 255, 0.34) 14% 31%, transparent 32%),
      linear-gradient(145deg, #79e8ff 0%, #0b91db 52%, #075b9b 100%);
    box-shadow:
      inset 0 2px 0 rgba(255, 255, 255, 0.92),
      inset 0 -9px 15px rgba(0, 44, 105, 0.24),
      0 5px 14px rgba(0, 62, 118, 0.28);
  }

  .brand strong {
    display: block;
    color: var(--ink-strong);
    font-size: 1.35rem;
    line-height: 1;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.94);
  }

  .brand small {
    display: block;
    margin-top: 3px;
    color: #2c6078;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .window-controls {
    display: grid;
    grid-template-columns: repeat(3, 22px);
    gap: 7px;
    padding: 4px;
    border: 1px solid rgba(255, 255, 255, 0.48);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.26);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
  }

  .window-controls span {
    width: 22px;
    height: 22px;
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: 50%;
    background:
      radial-gradient(circle at 34% 22%, #fff 0 13%, rgba(255, 255, 255, 0.44) 14% 28%, transparent 29%),
      linear-gradient(180deg, #82eaff 0%, #1a9fe2 52%, #0860a3 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      inset 0 -4px 8px rgba(0, 44, 110, 0.28),
      0 1px 5px rgba(0, 46, 95, 0.25);
  }

  .window-controls span:nth-child(2) {
    background:
      radial-gradient(circle at 34% 22%, #fff 0 13%, rgba(255, 255, 255, 0.44) 14% 28%, transparent 29%),
      linear-gradient(180deg, #bdfc7c 0%, #58bd44 52%, #1c7b35 100%);
  }

  .window-controls span:nth-child(3) {
    background:
      radial-gradient(circle at 34% 22%, #fff 0 13%, rgba(255, 255, 255, 0.44) 14% 28%, transparent 29%),
      linear-gradient(180deg, #ffd577 0%, #ff8d21 52%, #b84f18 100%);
  }

  .primary-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 10px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0.18)),
      rgba(225, 251, 255, 0.38);
  }

  .primary-nav a,
  .aqua-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 7px 14px;
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: 999px;
    color: #fff;
    font-weight: 800;
    text-align: center;
    text-decoration: none;
    text-shadow: 0 1px 2px rgba(0, 54, 98, 0.68);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.34) 43%, rgba(14, 151, 221, 0.96) 44%, rgba(5, 85, 156, 0.98) 100%),
      var(--blue);
    box-shadow:
      inset 0 2px 0 rgba(255, 255, 255, 0.88),
      inset 0 -8px 14px rgba(0, 45, 105, 0.24),
      0 5px 13px rgba(0, 72, 139, 0.28);
    transition: transform 160ms ease, filter 160ms ease, box-shadow 160ms ease;
  }

  .primary-nav a[aria-current='page'] {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.34) 43%, rgba(74, 190, 82, 0.96) 44%, rgba(24, 126, 61, 0.98) 100%),
      var(--green);
  }

  .primary-nav a:hover,
  .aqua-button:hover {
    transform: translateY(-1px);
    filter: brightness(1.08) saturate(1.08);
  }

  .aqua-button.green {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.34) 43%, rgba(75, 190, 83, 0.96) 44%, rgba(24, 126, 61, 0.98) 100%),
      var(--green);
  }

  .aqua-button.amber {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.34) 43%, rgba(255, 164, 42, 0.97) 44%, rgba(190, 75, 18, 0.98) 100%),
      var(--amber);
  }

  .aqua-button.rose {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.34) 43%, rgba(225, 75, 165, 0.96) 44%, rgba(139, 40, 118, 0.98) 100%),
      var(--rose);
  }

  .primary-nav a:focus-visible,
  .aqua-button:focus-visible {
    outline: 3px solid rgba(255, 255, 255, 0.96);
    outline-offset: 3px;
  }

  .page-main {
    display: grid;
    gap: 16px;
    margin-top: 16px;
  }

  .glass-panel,
  .media-panel,
  .content-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .glass-panel::before,
  .media-panel::before,
  .content-card::before {
    position: absolute;
    inset: 1px 1px auto;
    height: 38%;
    border-radius: 16px 16px 50% 50% / 16px 16px 24px 24px;
    content: '';
    pointer-events: none;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0));
  }

  .page-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(260px, 0.9fr);
    gap: clamp(20px, 4vw, 40px);
    align-items: center;
    min-height: 420px;
    padding: clamp(22px, 4vw, 44px);
  }

  .page-hero > *,
  .glass-panel > *,
  .media-panel > *,
  .content-card > * {
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    display: inline-flex;
    min-height: 28px;
    align-items: center;
    margin: 0 0 12px;
    padding: 5px 12px;
    border: 1px solid rgba(255, 255, 255, 0.74);
    border-radius: 999px;
    color: #075f91;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.32)),
      rgba(229, 253, 255, 0.62);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.86);
  }

  h1 {
    margin-bottom: 16px;
    color: var(--ink-strong);
    font-size: clamp(2.45rem, 1.6rem + 4vw, 5.1rem);
    line-height: 0.98;
    text-wrap: balance;
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.96),
      0 10px 28px rgba(0, 78, 134, 0.2);
  }

  h2 {
    margin-bottom: 12px;
    color: var(--ink-strong);
    font-size: clamp(1.45rem, 1.1rem + 1vw, 2.1rem);
    line-height: 1.12;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.92);
  }

  h3 {
    margin-bottom: 8px;
    color: #08476f;
    font-size: 1.1rem;
    line-height: 1.24;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.88);
  }

  .lead {
    max-width: 720px;
    color: #254f62;
    font-size: clamp(1.04rem, 0.98rem + 0.28vw, 1.22rem);
    line-height: 1.68;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.76);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 22px;
  }

  .site-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px;
    margin-top: 16px;
    padding: 12px 16px;
    border: 1px solid rgba(255, 255, 255, 0.58);
    border-radius: var(--radius-md);
    color: #235168;
    font-size: 0.9rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.38);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .muted-link {
    color: #075f91;
    font-weight: 800;
  }

  @supports not ((backdrop-filter: blur(14px)) or (-webkit-backdrop-filter: blur(14px))) {
    .site-window,
    .glass-panel,
    .media-panel,
    .content-card,
    .site-footer {
      background-color: rgba(244, 253, 255, 0.92);
    }
  }

  @media (max-width: 820px) {
    .page-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .titlebar {
      align-items: flex-start;
    }
  }

  @media (max-width: 640px) {
    .site-shell {
      width: min(100% - 16px, var(--max-width));
      margin-block: 8px 24px;
    }

    .site-window {
      border-radius: 18px;
    }

    .titlebar {
      display: grid;
      grid-template-columns: 1fr;
    }

    .window-controls {
      justify-self: start;
    }

    .primary-nav {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 10px;
    }

    .page-hero,
    .glass-panel,
    .media-panel {
      padding: 16px;
    }

    .aqua-button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    .primary-nav a,
    .aqua-button {
      transition: none;
    }
  }
</style>
