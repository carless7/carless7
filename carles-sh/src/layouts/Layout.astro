---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'carles.sh',
  description = 'The personal website of Carles Sánchez.',
} = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/music', label: 'Music' },
  { href: '/about', label: 'About' },
  { href: '/links', label: 'Links' },
];

const normalizePath = (path: string) => path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path;
const currentPath = normalizePath(Astro.url.pathname);
const isActive = (href: string) => currentPath === href || (href !== '/' && currentPath.startsWith(`${href}/`));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1599d4" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="masthead">
          <a class="brand" href="/" aria-label="carles.sh home">
            <span class="brand-mark" aria-hidden="true">C</span>
            <span>
              <strong>carles.sh</strong>
              <small>code, research, music &amp; the personal web</small>
            </span>
          </a>
          <div class="site-utility">
            <span>personal web home · updated July 2026</span>
            <a href="https://github.com/carless7">GitHub ↗</a>
          </div>
        </div>

        <nav class="primary-nav" aria-label="Primary navigation">
          {navItems.map((item) => (
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
      </header>

      <div id="main-content"><slot /></div>

      <footer class="site-footer">
        <div>
          <strong>carles.sh</strong> · © 2026 Carles Sánchez · last updated July 2026
        </div>
        <nav aria-label="Footer navigation">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
          <a href="https://github.com/carless7">GitHub ↗</a>
        </nav>
        <small>Best viewed with curiosity. Hand-built with Astro and ordinary CSS.</small>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --sky-1: #78d8f7;
    --sky-2: #ddf8ff;
    --water: #1599d4;
    --water-deep: #075787;
    --aqua: #47dde9;
    --leaf: #58b947;
    --leaf-deep: #20733a;
    --sun: #f5a326;
    --berry: #c64f94;
    --ink: #06334d;
    --muted: #315d72;
    --paper: #f9feff;
    --line-light: rgba(255, 255, 255, 0.88);
    --line-blue: #5aaed0;
    --module-shadow: 0 3px 8px rgba(0, 70, 105, 0.18);
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  html {
    min-height: 100%;
    cursor: url('/cursors/retro-pointer.svg') 4 2, auto;
  }

  body {
    min-width: 280px;
    min-height: 100vh;
    margin: 0;
    color: var(--ink);
    font: 14px/1.55 Verdana, Tahoma, Arial, sans-serif;
    background:
      radial-gradient(ellipse at 18% 12%, rgba(255, 255, 255, 0.78) 0 5%, transparent 15%),
      radial-gradient(ellipse at 78% 18%, rgba(255, 255, 255, 0.6) 0 6%, transparent 17%),
      linear-gradient(166deg, transparent 0 67%, rgba(255, 255, 255, 0.24) 67.2% 68%, transparent 68.2%),
      linear-gradient(180deg, var(--sky-1) 0%, var(--sky-2) 66%, #b7e88d 67%, #69ba53 100%);
    background-attachment: fixed;
  }

  a,
  button,
  summary,
  [role='button'] {
    cursor: url('/cursors/retro-link.svg') 8 2, pointer;
  }

  input,
  textarea,
  [contenteditable='true'] {
    cursor: text;
  }

  a {
    color: #075f91;
  }

  a:hover {
    color: var(--leaf-deep);
  }

  :focus-visible {
    outline: 3px solid #ffbd3d;
    outline-offset: 2px;
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1,
  h2,
  h3 {
    color: var(--water-deep);
    font-family: 'Trebuchet MS', Verdana, sans-serif;
    line-height: 1.2;
  }

  h1 {
    margin-bottom: 10px;
    font-size: clamp(1.6rem, 3vw, 2rem);
  }

  h2 {
    margin-bottom: 8px;
    font-size: 1.25rem;
  }

  h3 {
    margin-bottom: 6px;
    font-size: 1.05rem;
  }

  p {
    margin-bottom: 12px;
  }

  ::selection {
    color: #fff;
    background: var(--water-deep);
  }

  .skip-link {
    position: fixed;
    top: 6px;
    left: 6px;
    z-index: 20;
    padding: 8px 12px;
    transform: translateY(-160%);
    border: 2px solid var(--water-deep);
    color: var(--ink);
    font-weight: bold;
    background: #fff;
  }

  .skip-link:focus {
    transform: none;
  }

  .site-shell {
    width: min(1040px, calc(100% - 24px));
    margin: 18px auto 32px;
    overflow: hidden;
    border: 1px solid #3d90b5;
    border-radius: 8px;
    background: rgba(232, 249, 255, 0.96);
    box-shadow: 0 12px 28px rgba(0, 76, 112, 0.24), inset 0 0 0 1px var(--line-light);
  }

  .site-header {
    border-bottom: 1px solid var(--water-deep);
    background: #d8f5ff;
  }

  .masthead {
    position: relative;
    display: flex;
    min-height: 92px;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 13px 18px 16px;
    overflow: hidden;
    background:
      radial-gradient(circle at 86% 22%, rgba(255, 255, 255, 0.9) 0 4%, transparent 13%),
      linear-gradient(112deg, rgba(255, 255, 255, 0.6) 0 9%, transparent 9.3% 16%, rgba(255, 255, 255, 0.24) 16.3% 22%, transparent 22.3%),
      linear-gradient(180deg, #a9eaff, #e9fbff 74%, #8cd56c 75%, #54aa45 100%);
    box-shadow: inset 0 1px 0 #fff;
  }

  .brand {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr);
    align-items: center;
    gap: 11px;
    color: var(--ink);
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    width: 54px;
    height: 54px;
    place-items: center;
    border: 1px solid #176f9a;
    border-radius: 50%;
    color: #fff;
    font: bold 25px/1 'Trebuchet MS', Verdana, sans-serif;
    text-shadow: 0 1px 2px #075787;
    background:
      radial-gradient(circle at 32% 24%, #fff 0 8%, rgba(255, 255, 255, 0.68) 9% 21%, transparent 22%),
      linear-gradient(145deg, #68e6ed, var(--water) 52%, var(--water-deep));
    box-shadow: inset 0 2px 0 rgba(255, 255, 255, 0.92), inset 0 -8px 12px rgba(0, 63, 105, 0.24), 0 3px 6px rgba(0, 73, 111, 0.28);
  }

  .brand strong {
    display: block;
    font: bold 31px/1 'Trebuchet MS', Verdana, sans-serif;
    letter-spacing: -1px;
    text-shadow: 0 1px 0 #fff;
  }

  .brand small {
    display: block;
    margin-top: 5px;
    color: var(--muted);
    font-size: 11px;
    font-weight: bold;
  }

  .site-utility {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--muted);
    font-size: 11px;
    font-weight: bold;
  }

  .site-utility a {
    padding: 4px 7px;
    border: 1px solid #74b5ce;
    border-radius: 5px;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: inset 0 1px 0 #fff;
  }

  .primary-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 5px;
    min-height: 40px;
    padding: 5px 14px 0;
    background: linear-gradient(180deg, #d9f5ff, #9edbf1);
    box-shadow: inset 0 1px 0 #fff;
  }

  .primary-nav a,
  .bevel-button {
    display: inline-flex;
    min-height: 35px;
    align-items: center;
    justify-content: center;
    padding: 7px 14px;
    border: 1px solid #075787;
    border-radius: 7px 7px 0 0;
    color: #fff;
    font-size: 12px;
    font-weight: bold;
    text-decoration: none;
    text-shadow: 0 1px 1px #034d73;
    background: linear-gradient(180deg, #8ae8ff 0%, #31b5e5 42%, #168bc5 43%, #075787 100%);
    box-shadow: inset 1px 1px 0 rgba(255, 255, 255, 0.86), inset -1px -1px 0 rgba(0, 58, 92, 0.45), 0 2px 3px rgba(0, 70, 105, 0.22);
  }

  .primary-nav a[aria-current='page'] {
    border-color: var(--leaf-deep);
    background: linear-gradient(180deg, #c9f899 0%, #7bd057 42%, #54ad42 43%, #20733a 100%);
  }

  .primary-nav a:hover,
  .bevel-button:hover {
    color: #fff;
    filter: brightness(1.08);
  }

  .primary-nav a:active,
  .bevel-button:active {
    transform: translateY(1px);
    box-shadow: inset 1px 2px 3px rgba(0, 65, 100, 0.28);
  }

  #main-content {
    min-height: 330px;
  }

  .page-main {
    display: grid;
    gap: 16px;
    padding: 16px;
  }

  .window,
  .sidebar-module {
    overflow: hidden;
    border: 1px solid var(--line-blue);
    border-radius: 8px;
    background: var(--paper);
    box-shadow: var(--module-shadow), inset 0 0 0 1px var(--line-light);
  }

  .sidebar-module {
    border-radius: 6px;
  }

  .window-title,
  .section-bar {
    display: flex;
    min-height: 32px;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 6px 10px;
    border-bottom: 1px solid #3c8fb5;
    color: var(--water-deep);
    background: linear-gradient(180deg, #effcff 0%, #bdebf9 46%, #99d9ef 47%, #c9eff9 100%);
    box-shadow: inset 0 1px 0 #fff;
  }

  .window-title h2,
  .window-title h3,
  .window-title .window-label,
  .section-bar h2,
  .section-bar h3 {
    margin: 0;
    color: var(--water-deep);
    font-family: 'Trebuchet MS', Verdana, sans-serif;
    font-size: 15px;
    font-weight: bold;
    line-height: 1.2;
  }

  .window-title small,
  .section-bar small {
    color: var(--muted);
    font-size: 10px;
    font-weight: bold;
    text-transform: uppercase;
  }

  .window-body {
    padding: 12px;
  }

  .window-body.reading {
    padding: 18px 20px;
  }

  .page-heading .window-body {
    padding: 14px 16px;
  }

  .page-heading h1 {
    margin-bottom: 5px;
  }

  .page-heading p:last-child,
  .window-body > :last-child {
    margin-bottom: 0;
  }

  .small-label {
    margin-bottom: 5px;
    color: var(--leaf-deep);
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .bevel-button {
    min-height: 32px;
    border-radius: 5px;
    padding: 6px 10px;
  }

  .bevel-button.green {
    border-color: var(--leaf-deep);
    background: linear-gradient(180deg, #c9f899 0%, #72ca51 44%, #4ca43e 45%, #20733a 100%);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .status-line {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin: 0 0 8px;
  }

  .status-dot {
    flex: 0 0 auto;
    width: 10px;
    height: 10px;
    margin-top: 5px;
    border: 1px solid #2a758f;
    border-radius: 50%;
    background: var(--water);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .status-dot.live {
    border-color: var(--leaf-deep);
    background: var(--leaf);
  }

  .status-dot.paused {
    border-color: #9b6317;
    background: var(--sun);
  }

  .status-dot.archive {
    border-color: #627681;
    background: #9caeb6;
  }

  .two-column {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 260px;
    gap: 16px;
    align-items: start;
  }

  .sidebar-stack {
    display: grid;
    gap: 12px;
  }

  .plain-list {
    margin: 0;
    padding-left: 19px;
  }

  .plain-list li + li {
    margin-top: 6px;
  }

  .site-footer {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 5px 14px;
    padding: 10px 14px;
    border-top: 1px solid var(--line-blue);
    color: var(--muted);
    font-size: 10px;
    background: linear-gradient(180deg, #dff7ff, #b9e5f4);
    box-shadow: inset 0 1px 0 #fff;
  }

  .site-footer nav {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    justify-content: flex-end;
  }

  .site-footer small {
    grid-column: 1 / -1;
  }

  @media (max-width: 900px) {
    .two-column {
      grid-template-columns: 1fr;
    }

    .site-utility span {
      display: none;
    }
  }

  @media (max-width: 680px) {
    body {
      background-attachment: scroll;
    }

    .site-shell {
      width: calc(100% - 16px);
      margin: 8px auto 20px;
    }

    .masthead {
      min-height: 82px;
      padding: 10px 12px;
    }

    .brand {
      grid-template-columns: 44px minmax(0, 1fr);
    }

    .brand-mark {
      width: 44px;
      height: 44px;
      font-size: 21px;
    }

    .brand strong {
      font-size: 25px;
    }

    .brand small {
      font-size: 9px;
    }

    .site-utility {
      display: none;
    }

    .primary-nav {
      gap: 4px;
      padding: 5px 7px 0;
    }

    .primary-nav a {
      flex: 1 1 88px;
      padding-inline: 8px;
    }

    .page-main {
      gap: 12px;
      padding: 10px;
    }

    .window-body.reading {
      padding: 14px;
    }

    .site-footer {
      grid-template-columns: 1fr;
    }

    .site-footer nav {
      justify-content: flex-start;
    }

    .site-footer small {
      grid-column: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }
</style>
