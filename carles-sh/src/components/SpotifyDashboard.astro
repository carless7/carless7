<section class="spotify-dashboard" aria-label="Spotify listening information">
  <div class="music-top">
    <section class="player-cabinet" id="listening-now" aria-labelledby="player-title">
      <div class="player-heading">
        <h2 id="player-title">carles.sh music player</h2>
        <span id="spotify-status"><i class="connection-light loading"></i> Checking connection</span>
      </div>
      <div class="player-body">
        <div class="album-art" id="album-art">
          <span class="record-placeholder" aria-hidden="true"></span>
          <img hidden alt="" />
        </div>
        <div class="track-screen">
          <p class="screen-label" id="track-label">Connection status</p>
          <h2 id="track-title">Loading Spotify activity…</h2>
          <p id="track-detail">The rest of the music room remains available while this check runs.</p>
          <a id="track-link" hidden>Open track on Spotify ↗</a>
        </div>
      </div>
      <noscript><p class="no-script">Live Spotify data needs JavaScript. The page structure and links still work without it.</p></noscript>
    </section>

    <aside class="sidebar-stack music-sidebar" aria-label="Music page navigation">
      <section class="sidebar-module">
        <div class="window-title"><h2>On this page</h2></div>
        <nav class="music-nav" aria-label="Music page sections">
          <a href="#listening-now">Listening now</a>
          <a href="#top-artists">Top artists</a>
          <a href="#playlists">Public playlists</a>
        </nav>
      </section>
      <section class="sidebar-module">
        <div class="window-title"><h2>Music links</h2></div>
        <div class="window-body">
          <p><a href="https://github.com/orgs/spotifai-tfg">SpotifAI project ↗</a></p>
          <p class="status-line"><span class="status-dot"></span><span>Spotify is read-only here; visitors never sign in.</span></p>
        </div>
      </section>
    </aside>
  </div>

  <div class="music-data">
    <section class="window artist-panel" aria-labelledby="artist-title">
      <div class="window-title">
        <h2 id="artist-title">Frequently returned to</h2>
        <small>top artists</small>
      </div>
      <ol class="artist-list" id="top-artists" aria-live="polite">
        <li class="data-state">Loading top-artist data…</li>
      </ol>
    </section>

    <section class="window playlist-panel" aria-labelledby="playlist-title">
      <div class="window-title">
        <h2 id="playlist-title">Public playlist shelves</h2>
        <small>Spotify library</small>
      </div>
      <div class="playlist-shelf" id="playlists" aria-live="polite">
        <p class="data-state">Loading public playlists…</p>
      </div>
    </section>
  </div>
</section>

<script>
  const getJson = async (url: string) => {
    const response = await fetch(url, { headers: { Accept: 'application/json' } });
    const data = await response.json().catch(() => ({}));
    if (!response.ok || !data.ok) throw new Error(data.error || 'Spotify is unavailable.');
    return data;
  };

  const status = document.querySelector('#spotify-status');
  const statusLight = status?.querySelector('.connection-light');
  const setStatus = (text: string, state: string) => {
    if (!status || !statusLight) return;
    status.lastChild!.textContent = ` ${text}`;
    statusLight.className = `connection-light ${state}`;
  };

  const loadNowPlaying = async () => {
    const title = document.querySelector('#track-title');
    const detail = document.querySelector('#track-detail');
    const label = document.querySelector('#track-label');
    const link = document.querySelector<HTMLAnchorElement>('#track-link');
    const art = document.querySelector<HTMLDivElement>('#album-art');

    try {
      const data = await getJson('/api/spotify/now-playing.json');
      setStatus('Spotify connected', 'online');
      if (!data.playing || !data.track) {
        if (label) label.textContent = 'Playback status';
        if (title) title.textContent = 'Nothing playing right now';
        if (detail) detail.textContent = 'The connection is working; playback is currently paused or idle.';
        return;
      }

      if (label) label.textContent = 'Now playing';
      if (title) title.textContent = data.track.name;
      if (detail) detail.textContent = `${data.track.artists.join(', ')} · ${data.track.album}`;
      if (link) {
        link.href = data.track.url;
        link.hidden = false;
      }
      const image = art?.querySelector<HTMLImageElement>('img');
      const placeholder = art?.querySelector<HTMLElement>('.record-placeholder');
      if (image && data.track.image) {
        image.src = data.track.image;
        image.alt = `Album artwork for ${data.track.name}`;
        image.hidden = false;
        placeholder?.setAttribute('hidden', '');
      }
    } catch {
      setStatus('Spotify unavailable', 'offline');
      if (label) label.textContent = 'Connection status';
      if (title) title.textContent = 'Spotify is unavailable';
      if (detail) detail.textContent = 'Live listening data could not be reached. The rest of the music room still works.';
    }
  };

  const loadArtists = async () => {
    const list = document.querySelector<HTMLOListElement>('#top-artists');
    if (!list) return;
    try {
      const { artists } = await getJson('/api/spotify/top-artists.json');
      list.replaceChildren();
      if (!artists.length) {
        const item = document.createElement('li');
        item.className = 'data-state';
        item.textContent = 'No top-artist data is available yet.';
        list.append(item);
        return;
      }
      artists.forEach((artist: { name: string; image: string; url: string }, index: number) => {
        const item = document.createElement('li');
        item.className = 'artist-row';
        const rank = document.createElement('span');
        rank.className = 'rank';
        rank.textContent = String(index + 1).padStart(2, '0');
        if (artist.image) {
          const image = document.createElement('img');
          image.src = artist.image;
          image.alt = '';
          image.loading = 'lazy';
          item.append(rank, image);
        } else {
          const imageFallback = document.createElement('span');
          imageFallback.className = 'artist-image-fallback';
          imageFallback.setAttribute('aria-hidden', 'true');
          item.append(rank, imageFallback);
        }
        const link = document.createElement('a');
        link.href = artist.url;
        link.textContent = artist.name;
        item.append(link);
        list.append(item);
      });
    } catch {
      list.replaceChildren(Object.assign(document.createElement('li'), { className: 'data-state', textContent: 'Top-artist data is unavailable.' }));
    }
  };

  const loadPlaylists = async () => {
    const shelf = document.querySelector<HTMLDivElement>('#playlists');
    if (!shelf) return;
    try {
      const { playlists } = await getJson('/api/spotify/playlists.json');
      shelf.replaceChildren();
      if (!playlists.length) {
        shelf.append(Object.assign(document.createElement('p'), { className: 'data-state', textContent: 'No public playlists are available.' }));
        return;
      }
      playlists.forEach((playlist: { name: string; image: string; url: string; tracks: number }) => {
        const link = document.createElement('a');
        link.className = 'playlist-item';
        link.href = playlist.url;
        if (playlist.image) {
          const image = document.createElement('img');
          image.src = playlist.image;
          image.alt = '';
          image.loading = 'lazy';
          link.append(image);
        }
        const copy = document.createElement('span');
        copy.className = 'playlist-copy';
        copy.append(
          Object.assign(document.createElement('strong'), { textContent: playlist.name }),
          Object.assign(document.createElement('small'), { textContent: `${playlist.tracks} tracks` }),
        );
        link.append(copy);
        shelf.append(link);
      });
    } catch {
      shelf.replaceChildren(Object.assign(document.createElement('p'), { className: 'data-state', textContent: 'Public playlists are unavailable.' }));
    }
  };

  void Promise.allSettled([loadNowPlaying(), loadArtists(), loadPlaylists()]);
</script>

<style>
