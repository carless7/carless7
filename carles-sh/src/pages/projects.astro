---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    badge: 'S',
    title: 'SpotifAI music recommendation',
    description: 'Applied AI work exploring music discovery, recommendation, and explainable results.',
    tags: ['Python', 'machine learning', 'research'],
    status: 'Active research',
    year: '2026',
    href: 'https://github.com/orgs/spotifai-tfg',
    action: 'Visit project',
  },
  {
    badge: 'C',
    title: 'carles.sh',
    description: 'A hand-built Astro site for technical work, personal interests, and the independent web.',
    tags: ['Astro', 'CSS', 'personal web'],
    status: 'Live',
    year: '2026',
    href: 'https://github.com/carless7/carless7',
    action: 'View source',
  },
];
---

<Layout title="carles.sh | Projects" description="Software, research, and experiments by Carles Sánchez.">
  <main class="page-main projects-page">
    <header class="window page-heading">
      <div class="window-title"><strong class="window-label">Project index</strong><small>technical archive</small></div>
      <div class="window-body">
        <h1>Projects, research, and useful experiments</h1>
        <p>Only work with a real public destination is listed. Detailed project files will appear when their problem, role, and result can be documented honestly.</p>
      </div>
    </header>

    <div class="two-column">
      <section class="window project-window" aria-labelledby="project-list-title">
        <div class="window-title">
          <h2 id="project-list-title">Chronological project list</h2>
          <small>{projects.length} public entries</small>
        </div>
        <div class="project-list">
          {projects.map((project) => (
            <article class="project-row">
              <span class="project-badge" aria-hidden="true">{project.badge}</span>
              <div class="project-copy">
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <ul class="tag-list" aria-label="Topics">
                  {project.tags.map((tag) => <li>{tag}</li>)}
                </ul>
              </div>
              <dl class="project-meta">
                <div><dt>Status</dt><dd>{project.status}</dd></div>
                <div><dt>Year</dt><dd>{project.year}</dd></div>
              </dl>
              <a class="project-link" href={project.href}>{project.action} ↗</a>
            </article>
          ))}
        </div>
      </section>

      <aside class="sidebar-stack" aria-label="Project index information">
        <section class="sidebar-module">
          <div class="window-title"><h2>Topic shelf</h2></div>
          <div class="window-body">
            <ul class="plain-list">
              <li>Machine learning</li>
              <li>Formal XAI</li>
              <li>Cybersecurity</li>
              <li>Data science</li>
              <li>Systems in C/C++</li>
            </ul>
          </div>
        </section>

        <section class="sidebar-module">
          <div class="window-title"><h2>Status legend</h2></div>
          <div class="window-body">
            <p class="status-line"><span class="status-dot live"></span><span><strong>Live</strong> · public and usable</span></p>
            <p class="status-line"><span class="status-dot"></span><span><strong>Active</strong> · current work</span></p>
            <p class="status-line"><span class="status-dot archive"></span><span><strong>Archive</strong> · no longer maintained</span></p>
          </div>
        </section>

        <section class="sidebar-module">
          <div class="window-title"><h2>Repositories</h2></div>
          <div class="window-body">
            <p><a href="https://github.com/carless7">carless7 on GitHub ↗</a></p>
            <p><a href="https://github.com/orgs/spotifai-tfg">SpotifAI organization ↗</a></p>
          </div>
        </section>
      </aside>
    </div>
  </main>
</Layout>

<style>
  .project-list {
    display: grid;
  }

  .project-row {
    display: grid;
    grid-template-columns: 48px minmax(0, 1fr) 108px;
    grid-template-rows: auto auto;
    gap: 5px 9px;
    align-items: start;
    min-height: 88px;
    padding: 9px 10px;
  }

  .project-badge,
  .project-copy {
    grid-row: 1 / 3;
  }

  .project-row + .project-row {
    border-top: 1px solid #b9dce9;
  }

  .project-row:nth-child(even) {
    background: #eefaff;
  }

  .project-badge {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border: 1px solid var(--water-deep);
    border-radius: 6px;
    color: #fff;
    font: bold 21px/1 'Trebuchet MS', Verdana, sans-serif;
    text-shadow: 0 1px 1px #03496d;
    background: linear-gradient(145deg, #8feaff, var(--water) 54%, var(--water-deep));
    box-shadow: inset 0 1px 0 #fff, 0 2px 4px rgba(0, 70, 100, 0.2);
  }

  .project-copy h3,
  .project-copy p {
    margin-bottom: 5px;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    padding: 2px 5px;
    border: 1px solid #9fcddd;
    border-radius: 3px;
    color: var(--muted);
    font-size: 9px;
    font-weight: bold;
    background: #edfaff;
  }

  .project-meta {
    grid-column: 3;
    grid-row: 1;
    margin: 0;
    font-size: 10px;
  }

  .project-meta div + div {
    margin-top: 6px;
  }

  .project-meta dt {
    color: var(--muted);
    font-weight: bold;
    text-transform: uppercase;
  }

  .project-meta dd {
    margin: 1px 0 0;
    color: var(--ink);
  }

  .project-link {
    grid-column: 3;
    grid-row: 2;
    align-self: end;
    justify-self: start;
    font-size: 11px;
    font-weight: bold;
  }

  @media (max-width: 520px) {
    .project-row {
      grid-template-columns: 42px minmax(0, 1fr);
      grid-template-rows: auto;
    }

    .project-badge,
    .project-copy {
      grid-row: auto;
    }

    .project-badge {
      width: 42px;
      height: 42px;
    }

    .project-meta {
      grid-column: 2;
      grid-row: auto;
      display: flex;
      gap: 14px;
    }

    .project-meta div + div {
      margin-top: 0;
    }

    .project-link {
      grid-column: 2;
      grid-row: auto;
      justify-self: start;
    }
  }
</style>
