---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 | carles.sh" description="The requested page was not found on carles.sh.">
  <main class="page-main lost-page">
    <section class="window lost-window">
      <div class="window-title"><strong class="window-label">Wrong turn</strong><small>error 404</small></div>
      <div class="window-body reading">
        <span class="lost-orb" aria-hidden="true">?</span>
        <div>
          <h1>This page is not in the directory.</h1>
          <p>The address may have moved, or the link may be older than this version of the site.</p>
          <nav class="room-links" aria-label="Main site rooms">
            <a href="/">Home</a>
            <a href="/projects">Projects</a>
            <a href="/music">Music</a>
            <a href="/about">About</a>
            <a href="/links">Links</a>
          </nav>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .lost-page {
    min-height: 420px;
    place-items: center;
  }

  .lost-window {
    width: min(620px, 100%);
  }

  .lost-window .window-body {
    display: grid;
    grid-template-columns: 86px minmax(0, 1fr);
    gap: 18px;
    align-items: center;
  }

  .lost-orb {
    display: grid;
    width: 86px;
    height: 86px;
    place-items: center;
    border: 2px solid var(--water-deep);
    border-radius: 50%;
    color: #fff;
    font: bold 38px/1 'Trebuchet MS', Verdana, sans-serif;
    text-shadow: 0 1px 2px var(--water-deep);
    background: radial-gradient(circle at 32% 24%, #fff 0 7%, rgba(255,255,255,.6) 8% 18%, transparent 19%), linear-gradient(145deg, var(--aqua), var(--water) 52%, var(--water-deep));
    box-shadow: inset 0 1px 0 #fff, 0 4px 8px rgba(0, 65, 95, 0.22);
  }

  .room-links {
    display: flex;
    flex-wrap: wrap;
    gap: 7px 14px;
    margin-top: 14px;
    font-weight: bold;
  }

  @media (max-width: 520px) {
    .lost-window .window-body {
      grid-template-columns: 1fr;
    }

    .lost-orb {
      width: 66px;
      height: 66px;
      font-size: 30px;
    }
  }
</style>
